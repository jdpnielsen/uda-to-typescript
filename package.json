{
	"name": "@jdpnielsen/uda-to-typescript",
	"type": "module",
	"version": "17.0.0",
	"description": "CLI to convert Umbraco UDA files to typescript definitions",
	"author": {
		"name": "Joshua Nielsen",
		"email": "jdpnielsen@gmail.com",
		"url": "https://github.com/jdpnielsen"
	},
	"license": "MIT",
	"homepage": "https://github.com/jdpnielsen/uda-to-typescript#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jdpnielsen/uda-to-typescript.git"
	},
	"bugs": {
		"url": "https://github.com/jdpnielsen/uda-to-typescript/issues"
	},
	"keywords": [
		"typescript",
		"umbraco",
		"uda",
		"generator"
	],
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./cli": {
			"import": "./dist/cli.mjs",
			"require": "./dist/cli.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"bin": {
		"uda-to-typescript": "./dist/cli.mjs"
	},
	"files": [
		"!lib/__tests__/**/*",
		"bin/**/*",
		"dist/**/*",
		"templates/**/*"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"cm": "cz",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"start": "tsx ./src/cli.ts",
		"prepare": "husky",
		"semantic-release": "semantic-release",
		"test": "vitest --typecheck",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"change-case": "^5.4.4",
		"commander": "^14.0.3",
		"cosmiconfig": "^9.0.0",
		"glob": "^13.0.6",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^2.25.1",
		"@arethetypeswrong/core": "^0.18.2",
		"@semantic-release/changelog": "^6.0.3",
		"@types/node": "^22.19.11",
		"commitizen": "^4.2.4",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.39.3",
		"execa": "^9.6.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"publint": "^0.3.17",
		"semantic-release": "^25.0.3",
		"tsdown": "^0.20.3",
		"tsx": "^4.21.0",
		"vitest": "^4.0.18"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"lint-staged": {
		"*.ts": "eslint --cache --cache-location .eslintcache --fix"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			[
				"@semantic-release/commit-analyzer",
				{
					"preset": "conventionalcommits",
					"releaseRules": [
						{
							"type": "build",
							"scope": "deps",
							"release": "patch"
						}
					]
				}
			],
			[
				"@semantic-release/release-notes-generator",
				{
					"preset": "conventionalcommits",
					"presetConfig": {
						"types": [
							{
								"type": "feat",
								"section": "Features"
							},
							{
								"type": "fix",
								"section": "Bug Fixes"
							},
							{
								"type": "build",
								"section": "Dependencies and Other Build Updates",
								"hidden": false
							}
						]
					}
				}
			],
			"@semantic-release/changelog",
			"@semantic-release/npm",
			"@semantic-release/github"
		]
	}
}
